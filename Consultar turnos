<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estética & Bienestar - Reservas Premium</title>
    <style>
        :root {
            --primary: #8da388; /* Verde suave botánico */
            --primary-dark: #6e806a;
            --bg-overlay: rgba(255, 255, 255, 0.92); /* Fondo blanco traslúcido para las tarjetas */
            --text-dark: #333333;
            --text-light: #555555;
            --white: #ffffff;
            --accent: #e0a388; /* Tono coral suave */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        }

        body {
            /* Imagen de fondo de plantas muy difuminada */
            background-image: url('https://images.unsplash.com/photo-1518173946687-a4c8192721f5?q=80&w=1974&auto=format&fit=crop'); 
            background-size: cover;
            background-attachment: fixed;
            background-position: center;
            color: var(--text-dark);
            line-height: 1.6;
            filter: grayscale(10%); /* Toque sutil */
        }

        /* Capa superpuesta para dar el efecto difuminado general */
        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255, 255, 255, 0.7); /* Aclara un poco */
            backdrop-filter: blur(10px); /* Difuminado fuerte del fondo */
            z-index: -1;
        }

        header {
            background-color: var(--bg-overlay);
            text-align: center;
            padding: 50px 20px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        }

        header h1 {
            font-size: 2.5rem;
            color: var(--primary-dark);
            margin-bottom: 12px;
            font-weight: 300;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        header p {
            color: var(--text-light);
            font-size: 1.1rem;
            font-weight: 300;
        }

        .container {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 25px;
            padding-bottom: 60px;
        }

        /* Info & Politicas */
        .info-card {
            background-color: var(--bg-overlay);
            border-left: 4px solid var(--primary);
            padding: 25px;
            border-radius: 8px;
            margin-bottom: 35px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.04);
            backdrop-filter: blur(5px);
        }

        .info-card h3 {
            color: var(--primary-dark);
            margin-bottom: 15px;
            font-weight: 400;
            letter-spacing: 1px;
        }

        .politicas {
            border-left: 4px solid var(--accent);
        }

        .politicas h3 {
            color: var(--accent);
        }

        /* Tabs de Categorías */
        .tabs {
            display: flex;
            overflow-x: auto;
            gap: 12px;
            margin-bottom: 25px;
            padding-bottom: 10px;
        }

        .tab-btn {
            background-color: var(--bg-overlay);
            border: 1px solid rgba(0,0,0,0.05);
            padding: 12px 24px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: 400;
            color: var(--text-light);
            white-space: nowrap;
            transition: all 0.3s ease;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

        .tab-btn.active, .tab-btn:hover {
            background-color: var(--primary);
            color: var(--white);
            border-color: var(--primary);
            box-shadow: 0 4px 10px rgba(141, 163, 136, 0.3);
        }

        /* Lista de Servicios */
        .services-container {
            margin-bottom: 50px;
        }

        .category-panel {
            display: none;
        }

        .category-panel.active {
            display: block;
        }

        .service-item {
            background-color: var(--bg-overlay);
            padding: 25px;
            border-radius: 10px;
            margin-bottom: 20px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.03);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid rgba(0, 0, 0, 0.03);
            backdrop-filter: blur(5px);
            transition: transform 0.2s ease;
        }

        .service-item:hover {
            transform: translateY(-3px);
        }

        .service-info h4 {
            font-size: 1.2rem;
            color: var(--text-dark);
            margin-bottom: 8px;
            font-weight: 400;
        }

        .service-meta {
            font-size: 0.95rem;
            color: var(--text-light);
        }

        .service-price {
            font-weight: 500;
            color: var(--primary-dark);
            font-size: 1.1rem;
        }

        .btn-select {
            background-color: var(--white);
            color: var(--primary-dark);
            border: 1px solid var(--primary-dark);
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .btn-select:hover {
            background-color: var(--primary-dark);
            color: var(--white);
        }

        /* Formulario */
        .booking-form {
            background-color: var(--bg-overlay);
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.06);
            backdrop-filter: blur(5px);
        }

        .booking-form h3 {
            color: var(--primary-dark);
            margin-bottom: 25px;
            font-weight: 300;
            letter-spacing: 1px;
            text-transform: uppercase;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding-bottom: 15px;
            text-align: center;
        }

